# Privy（从你 Privy Dashboard 里拿）
PRIVY_APP_ID=你的PrivyAppID
PRIVY_APP_SECRET=你的PrivyAppSecret

# Polymarket Builder（从 https://polymarket.com/settings?tab=builder 拿）
POLY_BUILDER_CODE=你的BuilderCode

# Builder API Key（同页面，用于 Relayer 免 gas 签名 — 与 builderCode 不同）
POLYMARKET_BUILDER_API_KEY=你的BuilderApiKey
POLYMARKET_BUILDER_SECRET=你的BuilderSecret
POLYMARKET_BUILDER_PASSPHRASE=你的BuilderPassphrase

# 服务器端口（不用改）
PORT=3001

# Keeper 轮询间隔（可选）
# KEEPER_INTERVAL_MS=60000
